#!/usr/bin/env bash
# Exactly what CI runs (.github/workflows/ci.yml): build, test, clippy.
# Green here means green there. CI's clippy is report-only (style-level lint
# debt is tracked separately), so this doesn't fail on lint warnings — the
# build and the tests are the gate.
set -euo pipefail
cd "$(dirname "$0")/.."

echo "── cargo build --workspace"
cargo build --workspace

echo "── cargo test --workspace"
cargo test --workspace

echo "── cargo clippy --workspace (report-only, like CI)"
cargo clippy --workspace || true

echo "── comment hygiene (no transient process labels in code comments)"
# Durable §-pointers (e.g. "DESIGN.html §5.0 D item 10", or a design memo's own "§9.4c Finding 3")
# are fine, sparingly — at most one per module. What's banned is a transient process artifact
# leaking into a comment instead of the invariant it protects: a review-round label, a numbered or
# lettered "finding" tagged to a review pass rather than to a stable document, or similar. Deliberately
# NOT in this deny-list:
#   * "D item <digit>" and a bare "Finding <digit>"/"finding <digit>" with no "#" — both are
#     legitimate, already-widespread durable pointers (the latter is how a design memo numbers its
#     own findings, e.g. query_utils.rs's "§9.4c Finding 3" — a stable document reference, not a
#     review-round label); "no more than one per module" is a per-file judgment call a sweep
#     review makes, not something a line-pattern grep can enforce without flagging every existing,
#     legitimate anchor.
# A "finding" IS flagged when it is `#`-tagged (`finding #7`, `finding-#7`) or a single capital
# letter (`finding A`, `finding B`) — both are how this project's own review rounds numbered their
# findings, never how a design memo does.
hygiene_pattern='review finding'
hygiene_pattern+='|PR #[0-9]+ review'
hygiene_pattern+='|post-merge (verification|review)'
hygiene_pattern+='|finding[ -]#[0-9]+'
hygiene_pattern+='|finding [A-Z]\b'
hygiene_pattern+='|adversarial.review'
hygiene_pattern+='|multi-agent review'
hygiene_pattern+='|round-[0-9] review'
hygiene_pattern+='|review fix'
hygiene_pattern+='|caught in (adversarial )?review'
hygiene_pattern+='|this PR.s\b'
hygiene_pattern+='|\bPR [A-Z]\b'
hygiene_pattern+='|\bPR #[0-9]+'
if hits=$(grep -rnEi --include='*.rs' "$hygiene_pattern" crates/); then
    echo "$hits"
    echo
    echo "Transient process-label comments found (see above) — state the durable invariant the" >&2
    echo "fix protects instead of the review round or finding number that motivated it." >&2
    exit 1
fi

echo "── docs freshness (bin/gen-docs)"
# Regenerate into a scratch directory (never touching docs/generated in place) and diff —
# catches both stale content and a deleted generated file, without side effects on a green run.
docs_scratch="$(mktemp -d)"
trap 'rm -rf "$docs_scratch"' EXIT
./bin/gen-docs "$docs_scratch" >/dev/null
if ! diff -ru docs/generated "$docs_scratch"; then
    echo
    echo "docs/generated/ is stale — run ./bin/gen-docs and commit the result." >&2
    exit 1
fi

echo "check: build + tests + docs green"
